import sys
import threading
import time
import json
import base64
import requests
import os
import uuid
import sqlite3
from pathlib import Path

# Cryptography
from cryptography.hazmat.primitives.asymmetric import rsa, padding
from cryptography.hazmat.primitives import serialization, hashes
from cryptography.hazmat.primitives.ciphers.aead import AESGCM

# Textual TUI
from textual.app import App, ComposeResult
from textual.containers import Container, Horizontal, Vertical, ScrollableContainer
from textual.widgets import Header, Footer, Input, Button, Static, ListView, ListItem, Label
from textual.screen import Screen
from textual import work

# --- Configuration ---
SERVER_URL = "http://localhost:8000"
CONFIG_DIR = Path.home() / ".config" / "chatters"

# --- Database Layer ---
class Database:
    def __init__(self, db_path):
        self.db_path = db_path
        self.conn = sqlite3.connect(db_path, check_same_thread=False)
        self.cursor = self.conn.cursor()
        self.lock = threading.Lock()
        self.init_db()

    def init_db(self):
        with self.lock:
            # We use the cryptographic signature as the PRIMARY KEY 'id'
            # This makes duplication mathematically impossible.
            self.cursor.execute('''
                CREATE TABLE IF NOT EXISTS messages (
                    id TEXT PRIMARY KEY, 
                    peer TEXT,
                    sender TEXT,
                    content TEXT,
                    timestamp REAL
                )
            ''')
            self.conn.commit()

    def add_message(self, sig_id, peer, sender, content, timestamp):
        with self.lock:
            try:
                # INSERT OR IGNORE: If we already have this signature, do nothing.
                self.cursor.execute('''
                    INSERT OR IGNORE INTO messages (id, peer, sender, content, timestamp)
                    VALUES (?, ?, ?, ?, ?)
                ''', (sig_id, peer, sender, content, timestamp))
                self.conn.commit()
                return self.cursor.rowcount > 0
            except Exception:
                return False

    def get_messages(self, peer):
        with self.lock:
            self.cursor.execute('''
                SELECT sender, content FROM messages 
                WHERE peer = ? 
                ORDER BY timestamp ASC
            ''', (peer,))
            return [{"sender": row[0], "text": row[1]} for row in self.cursor.fetchall()]

    def get_peers(self):
        with self.lock:
            self.cursor.execute('SELECT DISTINCT peer FROM messages')
            return [row[0] for row in self.cursor.fetchall()]

# --- Backend Logic ---
class Backend:
    def __init__(self):
        self.alias = None
        self.jwt = None
        self.priv_k = None
        self.pub_k = None
        self.pub_k_pem = None
        self.peer_pub_keys = {}
        self.active_sessions = {}
        self.db = None

    def get_user_dir(self):
        return CONFIG_DIR / self.alias

    def init_storage(self, alias):
        self.alias = alias
        d = self.get_user_dir()
        d.mkdir(parents=True, exist_ok=True)
        self.db = Database(d / "chat.db")

    def save_keys(self):
        d = self.get_user_dir()
        with open(d / "private_key.pem", "wb") as f:
            f.write(self.priv_k.private_bytes(
                encoding=serialization.Encoding.PEM,
                format=serialization.PrivateFormat.PKCS8,
                encryption_algorithm=serialization.NoEncryption()
            ))
        with open(d / "public_key.pem", "wb") as f:
            f.write(self.pub_k.public_bytes(
                encoding=serialization.Encoding.PEM,
                format=serialization.PublicFormat.SubjectPublicKeyInfo
            ))
        if self.jwt:
            with open(d / "token.txt", "w") as f: f.write(self.jwt)

    def load_state(self, alias):
        self.init_storage(alias) 
        d = self.get_user_dir()
        if not (d / "private_key.pem").exists(): return False
        try:
            with open(d / "private_key.pem", "rb") as f:
                self.priv_k = serialization.load_pem_private_key(f.read(), None)
            self.pub_k = self.priv_k.public_key()
            self.pub_k_pem = self.pub_k.public_bytes(
                serialization.Encoding.PEM, 
                serialization.PublicFormat.SubjectPublicKeyInfo
            ).decode('utf-8')
            if (d / "token.txt").exists():
                with open(d / "token.txt", "r") as f: self.jwt = f.read().strip()
            return True
        except: return False

    def generate_keys(self):
        self.priv_k = rsa.generate_private_key(65537, 2048)
        self.pub_k = self.priv_k.public_key()
        self.pub_k_pem = self.pub_k.public_bytes(
            serialization.Encoding.PEM, 
            serialization.PublicFormat.SubjectPublicKeyInfo
        ).decode('utf-8')

    def sign(self, data):
        return base64.b64encode(self.priv_k.sign(
            data.encode('utf-8'), padding.PKCS1v15(), hashes.SHA256()
        )).decode('utf-8')

    def verify(self, sender, data, sig_b64):
        if sender == self.alias: return True 
        if sender not in self.peer_pub_keys:
            if not self.fetch_peer_key(sender): return False
        try:
            self.peer_pub_keys[sender].verify(
                base64.b64decode(sig_b64),
                data.encode('utf-8'),
                padding.PKCS1v15(),
                hashes.SHA256()
            )
            return True
        except: return False

    def fetch_peer_key(self, target):
        try:
            r = requests.get(f"{SERVER_URL}/keys/{target}", headers={"Authorization": f"Bearer {self.jwt}"})
            if r.status_code == 200:
                pem = r.json()['publicKey'].encode('utf-8')
                self.peer_pub_keys[target] = serialization.load_pem_public_key(pem)
                return True
        except: pass
        return False

    def register_and_login(self, alias):
        self.alias = alias
        if not self.load_state(alias):
            self.generate_keys()
            self.init_storage(alias)
            r = requests.post(f"{SERVER_URL}/auth/register-challenge", json={"alias": alias})
            if r.status_code != 200: return False
            nonce = r.json()['nonce']
            r = requests.post(f"{SERVER_URL}/auth/register-complete", json={
                "alias": alias, "publicKey": self.pub_k_pem, "signedNonce": self.sign(nonce)
            })
            if r.status_code not in [201, 409]: return False
        
        r = requests.post(f"{SERVER_URL}/auth/login-challenge", json={"alias": alias})
        if r.status_code != 200: return False
        chal = r.json().get('challenge') or r.json().get('nonce')
        r = requests.post(f"{SERVER_URL}/auth/login-complete", json={
            "alias": alias, "signedChallenge": self.sign(chal)
        })
        if r.status_code == 200:
            self.jwt = r.json()['token']
            self.save_keys()
            return True
        return False

    def send_msg(self, target, text):
        if target not in self.active_sessions:
            if not self.fetch_peer_key(target): return False
            aes_key = AESGCM.generate_key(256)
            self.active_sessions[target] = aes_key
            enc_key = self.peer_pub_keys[target].encrypt(
                aes_key, padding.OAEP(padding.MGF1(hashes.SHA256()), hashes.SHA256(), None)
            )
            b64_key = base64.b64encode(enc_key).decode('utf-8')
            requests.post(f"{SERVER_URL}/messages", json={
                "recipientAlias": target, "type": "KEY_EXCHANGE", 
                "encryptedMessage": b64_key, "signature": self.sign(b64_key)
            }, headers={"Authorization": f"Bearer {self.jwt}"})

        iv = os.urandom(12)
        cipher = AESGCM(self.active_sessions[target]).encrypt(iv, text.encode('utf-8'), None)
        msg_b64 = base64.b64encode(iv + cipher).decode('utf-8')
        sig = self.sign(msg_b64)
        
        # FIX: Use 'sig' as the ID in database
        self.db.add_message(sig, target, "Me", text, time.time())

        requests.post(f"{SERVER_URL}/messages", json={
            "recipientAlias": target, "type": "TEXT", 
            "encryptedMessage": msg_b64, "signature": sig
        }, headers={"Authorization": f"Bearer {self.jwt}"})
        return True

    def decrypt_incoming(self, msgs):
        new_chats = set()
        for m in msgs:
            sender = m.get('senderAlias', 'Unknown')
            sig = m['signature']
            
            # Note: We rely on DB constraints for deduplication now, 
            # so we don't need a manual 'seen_signatures' set anymore.
            
            if not self.verify(sender, m['encryptedMessage'], sig): continue

            if m['type'] == "KEY_EXCHANGE":
                try:
                    raw = base64.b64decode(m['encryptedMessage'])
                    key = self.priv_k.decrypt(raw, padding.OAEP(padding.MGF1(hashes.SHA256()), hashes.SHA256(), None))
                    self.active_sessions[sender] = key
                except: pass
            
            elif m['type'] == "TEXT":
                is_me = (sender == self.alias)
                if not is_me and sender in self.active_sessions:
                    try:
                        blob = base64.b64decode(m['encryptedMessage'])
                        txt = AESGCM(self.active_sessions[sender]).decrypt(blob[:12], blob[12:], None).decode('utf-8')
                        
                        # FIX: Use 'sig' as the ID. 
                        # If we polled this message 5 times, DB will reject it 4 times.
                        if self.db.add_message(sig, sender, sender, txt, time.time()):
                            new_chats.add(sender)
                    except: pass
        return new_chats

backend = Backend()

# --- UI Components ---

class MessageWidget(Static):
    def __init__(self, sender, text, **kwargs):
        super().__init__(**kwargs)
        self.sender = sender
        self.text_content = text

    def compose(self) -> ComposeResult:
        is_me = self.sender == "Me"
        classes = "me" if is_me else "them"
        yield Label(self.text_content, classes=f"msg_bubble {classes}")
        yield Label(self.sender, classes=f"msg_label {classes}")

class LoginScreen(Screen):
    def compose(self) -> ComposeResult:
        yield Container(
            Vertical(
                Label("[bold]SilentChat v2.1[/]", id="login_title"),
                Input(placeholder="Enter alias...", id="login_input"),
                Button("Connect", id="login_btn", variant="success"),
                id="login_box"
            ),
            id="login_container"
        )
    
    def on_button_pressed(self, event: Button.Pressed):
        self.try_login()
    def on_input_submitted(self, event: Input.Submitted):
        self.try_login()
        
    def try_login(self):
        alias = self.query_one("#login_input", Input).value.strip()
        if not alias: return
        if backend.register_and_login(alias):
            self.app.push_screen(ChatScreen())
        else:
            self.query_one("#login_title", Label).update("[red]Failed[/]")

class ChatScreen(Screen):
    current_peer = None

    def compose(self) -> ComposeResult:
        yield Header(show_clock=True)
        with Horizontal():
            with Vertical(id="sidebar"):
                yield Label("CHATS", id="sidebar_title")
                yield ListView(id="user_list")
                with Container(id="new_chat_box"):
                    yield Input(placeholder="+ User", id="new_user_input")
            
            with Vertical(id="chat_area"):
                yield Label("Select a chat", id="chat_header")
                yield ScrollableContainer(id="messages_scroll")
                with Container(id="input_area"):
                    yield Input(placeholder="Message...", id="msg_input")
        yield Footer()

    def on_mount(self):
        self.refresh_sidebar()
        self.poll_loop()

    def refresh_sidebar(self):
        list_view = self.query_one("#user_list", ListView)
        current = [getattr(c, 'peer_id', None) for c in list_view.children]
        db_peers = backend.db.get_peers()
        
        if set(current) != set(db_peers):
            list_view.clear()
            for user in db_peers:
                item = ListItem(Label(f" {user} "))
                item.peer_id = user
                list_view.append(item)

    def load_chat(self, peer):
        self.current_peer = peer
        self.query_one("#chat_header", Label).update(f"[@{peer}]")
        scroll = self.query_one("#messages_scroll", ScrollableContainer)
        scroll.remove_children()
        
        msgs = backend.db.get_messages(peer)
        for msg in msgs:
            scroll.mount(MessageWidget(msg['sender'], msg['text']))
        
        self.call_later(scroll.scroll_end, animate=False)

    def on_list_view_selected(self, event: ListView.Selected):
        peer = getattr(event.item, "peer_id", None)
        if peer: self.load_chat(peer)

    def on_input_submitted(self, event: Input.Submitted):
        if event.input.id == "new_user_input":
            new_peer = event.value.strip()
            if new_peer:
                self.load_chat(new_peer)
                event.input.value = ""
        
        elif event.input.id == "msg_input":
            text = event.value.strip()
            if not text or not self.current_peer: return
            backend.send_msg(self.current_peer, text)
            
            # Simple UI refresh: Add the single message directly
            scroll = self.query_one("#messages_scroll", ScrollableContainer)
            scroll.mount(MessageWidget("Me", text))
            self.call_later(scroll.scroll_end, animate=False)
            event.input.value = ""

    @work(exclusive=True, thread=True)
    def poll_loop(self):
        while True:
            try:
                # We can now safely poll overlapping time windows
                since = time.time() - 5 
                r = requests.get(f"{SERVER_URL}/messages?since={since}", 
                                 headers={"Authorization": f"Bearer {backend.jwt}"},
                                 timeout=3)
                if r.status_code == 200:
                    msgs = r.json()
                    if msgs:
                        updated_peers = backend.decrypt_incoming(msgs)
                        if updated_peers:
                            self.app.call_from_thread(self.handle_updates, updated_peers)
            except: pass 
            time.sleep(1.0)

    def handle_updates(self, peers):
        self.refresh_sidebar()
        if self.current_peer in peers:
            # Safe reload from DB
            self.load_chat(self.current_peer)

class E2EEChatApp(App):
    CSS = """
    Screen { background: #1a1b26; color: #a9b1d6; }
    #login_container { align: center middle; }
    #login_box { width: 60; height: auto; background: #24283b; border: wide #7aa2f7; padding: 2; }
    #login_title { text-align: center; color: #7aa2f7; text-style: bold; margin-bottom: 1; }
    #login_btn { width: 100%; margin-top: 1; }

    #sidebar { width: 25%; background: #1f2335; border-right: solid #292e42; }
    #sidebar_title { padding: 1 2; background: #16161e; color: #7aa2f7; text-style: bold; }
    #user_list { height: 1fr; background: #1f2335; }
    ListItem { padding: 1 2; background: #1f2335; color: #c0caf5; }
    ListItem:hover { background: #292e42; }
    ListItem.-selected { background: #3d59a1; color: white; text-style: bold; }
    #new_chat_box { dock: bottom; height: auto; padding: 1; background: #16161e; }
    #new_user_input { border: none; background: #24283b; }

    #chat_area { width: 75%; background: #1a1b26; }
    #chat_header { text-align: center; background: #16161e; color: #bb9af7; padding: 1; border-bottom: solid #292e42; }
    #messages_scroll { height: 1fr; padding: 1 2; }
    MessageWidget { margin-bottom: 1; width: 100%; }
    .msg_bubble { padding: 1 2; background: #24283b; color: #c0caf5; width: auto; max-width: 70%; }
    .msg_label { color: #565f89; text-style: italic; }
    .me { align-horizontal: right; }
    .me .msg_bubble { background: #414868; color: white; border-left: none; }
    .me .msg_label { text-align: right; }
    .them { align-horizontal: left; }
    .them .msg_bubble { background: #24283b; border-left: solid #7aa2f7; }
    #input_area { dock: bottom; height: auto; padding: 1 2; background: #16161e; border-top: solid #292e42; }
    #msg_input { background: #24283b; border: none; color: white; }
    #msg_input:focus { border: solid #7aa2f7; }
    """
    def on_mount(self):
        self.push_screen(LoginScreen())

if __name__ == "__main__":
    app = E2EEChatApp()
    app.run()
